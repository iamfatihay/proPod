# API Configuration
# IMPORTANT: Update these values based on your network/environment
# - Development (local): Use your computer's local IP (find with: ipconfig)
# - Production: Use your production API URL

API_BASE_URL=http://YOUR_IP_HERE:8000
REACT_NATIVE_PACKAGER_HOSTNAME=YOUR_IP_HERE
EXPO_DEVTOOLS_LISTEN_ADDRESS=YOUR_IP_HERE

# Environment Mode
# Options: dev, prod
ENV=dev

# Example for different scenarios:
# Local development: API_BASE_URL=http://192.168.1.100:8000
# Production: API_BASE_URL=https://api.yourapp.com
# Android emulator: API_BASE_URL=http://10.0.2.2:8000
