# Backend API Configuration
# 
# DEVELOPMENT (WSL):
# Set your Windows IP address (find with: ipconfig | findstr "IPv4" in PowerShell)
# Example: API_BASE_URL=http://192.168.1.100:8000
API_BASE_URL=http://YOUR_WINDOWS_IP:8000
EXPO_PUBLIC_API_URL=http://YOUR_WINDOWS_IP:8000
#
# PRODUCTION:
# Set your production API URL
# API_BASE_URL=https://api.propod.com
# EXPO_PUBLIC_API_URL=https://api.propod.com

# Metro Bundler Configuration (WSL Development)
# Set to your Windows IP address for phone to connect
# This ensures Expo Metro bundler is accessible from your phone
REACT_NATIVE_PACKAGER_HOSTNAME=YOUR_WINDOWS_IP
EXPO_DEVTOOLS_LISTEN_ADDRESS=YOUR_WINDOWS_IP
