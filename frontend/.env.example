# ================================================================
# Frontend Environment Configuration
# ================================================================
#
# Recommended development mode:
#   cd frontend
#   npm run dev
#
# This runs ../scripts/start-dev-tunnel.sh, which starts:
#   1. FastAPI backend on localhost:8000
#   2. Static ngrok backend tunnel
#   3. Expo in tunnel mode
#
# Expo Go is not supported. Use a development build.
#
# ================================================================

# ── Backend API URL ──────────────────────────────────────────
#
# Regular development uses the static ngrok backend URL.
# This works for:
#   - real devices
#   - different WiFi networks
#   - mobile data
#   - 100ms webhook testing
#   - browser/web debug mode
#
# For local emulator-only testing, you can manually override this if needed.
#
API_BASE_URL=https://subsumable-submucronated-inga.ngrok-free.dev
EXPO_PUBLIC_API_URL=https://subsumable-submucronated-inga.ngrok-free.dev

# ── Metro Bundler Hostname ───────────────────────────────────
#
# Usually not needed in tunnel mode.
# Leave empty unless you are intentionally running Expo LAN mode.
#
REACT_NATIVE_PACKAGER_HOSTNAME=
EXPO_DEVTOOLS_LISTEN_ADDRESS=