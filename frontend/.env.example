# ================================================================
# Frontend Environment Configuration
# ================================================================
#
# RECOMMENDED: Use the startup scripts — no manual editing needed!
#   LAN mode (same WiFi):  bash scripts/start-dev.sh
#   Tunnel mode (webhooks/off-network): bash scripts/start-dev-tunnel.sh
#
# ================================================================

# ── Backend API URL ──────────────────────────────────────────
#
# Leave EMPTY for auto-detection (recommended for LAN development).
# apiService.js reads Expo's hostUri and constructs http://<metro-ip>:8000
# This works automatically when REACT_NATIVE_PACKAGER_HOSTNAME is set.
#
# Set explicitly only for:
#   - ngrok tunnel:  API_BASE_URL=https://abc123.ngrok-free.app
#   - production:    API_BASE_URL=https://api.yourapp.com
#
API_BASE_URL=
EXPO_PUBLIC_API_URL=

# ── Metro Bundler Hostname (WSL required) ────────────────────
#
# Must be your Windows WiFi IP (not WSL IP).
# This tells Expo Metro to advertise the Windows IP in QR codes,
# so your phone can reach Metro via the port forwarding rules.
#
# start-dev.sh sets this automatically. Update manually if needed:
#   Windows PowerShell: ipconfig | findstr "IPv4"
#
REACT_NATIVE_PACKAGER_HOSTNAME=YOUR_WINDOWS_IP
EXPO_DEVTOOLS_LISTEN_ADDRESS=YOUR_WINDOWS_IP
