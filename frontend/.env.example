# Backend API Configuration
# 
# DEVELOPMENT (auto-detection):
# Leave empty - Expo will automatically detect your computer's IP
API_BASE_URL=
EXPO_PUBLIC_API_URL=
#
# PRODUCTION (manual configuration):
# Set your production API URL
# API_BASE_URL=https://api.propod.com
# EXPO_PUBLIC_API_URL=https://api.propod.com
#
# LOCAL TESTING (specific IP):
# Uncomment and set your IP address
# API_BASE_URL=http://192.168.1.100:8000
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
