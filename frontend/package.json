{
  "name": "Volo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev": "expo start --dev-client --lan",
    "start:dev:tunnel": "expo start --dev-client --tunnel",
    "start:lan": "expo start --dev-client --lan",
    "_comment_ip": "⚠️ Development build required for native modules (expo-notifications, expo-audio). Expo Go not supported.",
    "dev": "bash ../scripts/start-dev.sh",
    "dev:tunnel": "bash ../scripts/start-dev-tunnel.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "eas build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest src/",
    "test:integration": "jest src/tests/__tests__/integration/",
    "test:e2e": "detox test",
    "test:e2e:build": "detox build",
    "test:e2e:ios": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:full": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "lint": "eslint src/ --ext .js,.jsx",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix"
  },
  "dependencies": {
    "@100mslive/react-native-hms": "^1.12.0",
    "@expo/metro-runtime": "~5.0.5",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.6",
    "expo": "~53.0.26",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-auth-session": "^6.2.0",
    "expo-blur": "~14.1.5",
    "expo-constants": "^17.1.7",
    "expo-dev-client": "^5.2.4",
    "expo-file-system": "~18.1.10",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "^7.1.5",
    "expo-media-library": "^17.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-system-ui": "~5.0.11",
    "expo-task-manager": "~13.1.6",
    "metro": "^0.82.0",
    "metro-config": "^0.82.0",
    "metro-resolver": "^0.82.0",
    "nativewind": "^2.0.11",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@testing-library/react-native": "^12.8.1",
    "cross-env": "^10.1.0",
    "detox": "^20.28.2",
    "detox-cli": "^1.0.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eas-cli": "^16.32.0",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.14",
    "react-native-reanimated": "~3.17.4",
    "react-test-renderer": "19.0.0",
    "tailwindcss": "^3.3.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "metro",
          "metro-config",
          "metro-resolver"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
