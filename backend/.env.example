# Environment Configuration
ENVIRONMENT=development

# API Base URL (IMPORTANT for audio files)
# Development (WSL): Use your Windows IP address (find with: ipconfig on Windows)
# Example: BASE_URL=http://192.168.1.100:8000
# Production: Use your production domain
# Example: BASE_URL=https://api.propod.com
BASE_URL=http://YOUR_IP_HERE:8000

# Database Configuration
DATABASE_URL=sqlite:///./app.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (Allow all origins in development)
# Production: Set specific domains only
CORS_ORIGINS=["*"]

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# AI Configuration
OPENAI_API_KEY=your-openai-api-key-here
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here
# AI Processing Options
AI_TRANSCRIPTION_MODEL=whisper-1
AI_ANALYSIS_MODEL=gpt-4-turbo-preview
AI_MAX_AUDIO_SIZE_MB=200
AI_TIMEOUT_SECONDS=300

# Email Configuration (Optional - for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=