# ProPod Backend — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Environment ───────────────────────────────────────────────────────────────
# Options: dev | prod
ENV=dev

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (WSL → Windows PostgreSQL): replace localhost with your Windows host IP
# Example: postgresql://postgres:postgres@192.168.1.100:5432/propod_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/propod_db
# Set to true to log all SQL queries (dev only)
DATABASE_ECHO=false

# ── API Base URL ──────────────────────────────────────────────────────────────
# Dev (local): your machine's IP or an ngrok tunnel
# Dev example: http://192.168.1.100:8000  or  https://xxxx.ngrok-free.app
# Production: your real API domain
BASE_URL=http://YOUR_IP_OR_DOMAIN:8000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin panel session secret (sqladmin)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=your-admin-secret-key-here-change-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev: allow all origins
# Production: restrict to your frontend domain, e.g. ["https://app.propod.com"]
CORS_ORIGINS=["*"]

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
# 100 MB in bytes
MAX_FILE_SIZE=104857600

# ── AI Configuration ──────────────────────────────────────────────────────────
# AI_PROVIDER options:
#   local   → free, uses on-device Whisper (no API key needed, slower)
#   openai  → paid, best quality (requires OPENAI_API_KEY)
#   hybrid  → free users get local, premium users get OpenAI
AI_PROVIDER=local

# Required when AI_PROVIDER=openai or hybrid
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# OpenAI model names (openai/hybrid mode)
AI_TRANSCRIPTION_MODEL=whisper-1
AI_ANALYSIS_MODEL=gpt-4o

# Local Whisper model size (local/hybrid mode)
# tiny (fastest, lowest quality) | base | small | medium | large | large-v3 | turbo (best speed/accuracy ratio)
WHISPER_MODEL_SIZE=base
# Device: cpu (works everywhere) | cuda (NVIDIA GPU) | mps (Apple Silicon)
WHISPER_DEVICE=cpu

# General AI limits
AI_MAX_AUDIO_SIZE_MB=200
AI_TIMEOUT_SECONDS=300

# ── Email (optional, production only) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# ── RTC — 100ms ───────────────────────────────────────────────────────────────
# Get these from dashboard.100ms.live → Developer → Credentials
HMS_APP_ACCESS_KEY=
HMS_APP_SECRET=
# Get from dashboard.100ms.live → Templates → your template → Template ID
HMS_TEMPLATE_ID=

# Optional: per-tier templates (create 3 templates in 100ms dashboard)
# If left empty, all tiers use HMS_TEMPLATE_ID above
HMS_TEMPLATE_ID_FREE=
HMS_TEMPLATE_ID_STANDARD=
HMS_TEMPLATE_ID_PREMIUM=

# Webhook secret for verifying 100ms webhook payloads
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Set the same value in dashboard.100ms.live → Developer → Webhooks
HMS_WEBHOOK_SECRET=
# Your backend webhook endpoint (ngrok tunnel for local dev, real domain for prod)
HMS_WEBHOOK_URL=https://YOUR_DOMAIN/api/rtc/webhook

# ── Storage — Cloudflare R2 (S3-compatible) ───────────────────────────────────
# Dev default: local (files saved to backend/media/)
# Production recommendation: s3 (Cloudflare R2 or AWS S3)
MEDIA_STORAGE_BACKEND=local

# Required when MEDIA_STORAGE_BACKEND=s3
MEDIA_S3_BUCKET=your-bucket-name
# Cloudflare R2 region is always "auto"
MEDIA_S3_REGION=auto
# R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Leave empty for standard AWS S3
MEDIA_S3_ENDPOINT_URL=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
# Public URL for serving files (R2 public bucket URL or CDN domain)
MEDIA_S3_PUBLIC_BASE_URL=
# Key prefix — use "dev/podcasts" locally to keep dev files separate from prod in the same bucket
# Production: podcasts
# Local dev: dev/podcasts
MEDIA_S3_PREFIX=dev/podcasts
