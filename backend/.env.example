# Environment Configuration
# Options: 'dev' for development, 'prod' for production
ENV=dev

# API Base URL (IMPORTANT for audio files)
# Development (WSL): Use your Windows IP address (find with: ipconfig on Windows)
# Example: BASE_URL=http://192.168.1.100:8000
# Production: Use your production domain
# Example: BASE_URL=https://api.propod.com
BASE_URL=http://YOUR_IP_HERE:8000

# Database Configuration
DATABASE_URL=sqlite:///./app.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (Allow all origins in development)
# Production: Set specific domains only
CORS_ORIGINS=["*"]

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# AI Configuration - FLEXIBLE PROVIDER SYSTEM
# Choose your AI provider based on budget and quality needs

# AI_PROVIDER Options:
# - "local"  = FREE (uses local Whisper, no API keys needed, slower)
# - "openai" = PAID (best quality, requires API key, ~$0.08 per 10min podcast)
# - "hybrid" = FREEMIUM (free users get local, premium users get OpenAI)
AI_PROVIDER=local

# OpenAI Configuration (only needed if AI_PROVIDER=openai or hybrid)
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# OpenAI Model Names (for openai/hybrid mode)
AI_TRANSCRIPTION_MODEL=whisper-1
AI_ANALYSIS_MODEL=gpt-4-turbo

# Local Whisper Configuration (for local/hybrid mode)
# Model sizes: tiny (fastest, lowest quality) → base (balanced) → small → medium → large (slowest, best quality)
WHISPER_MODEL_SIZE=base
# Device: cpu (works everywhere) | cuda (NVIDIA GPU) | mps (Apple Silicon)
WHISPER_DEVICE=cpu

# General AI Settings
AI_MAX_AUDIO_SIZE_MB=200
AI_TIMEOUT_SECONDS=300

# Email Configuration (Optional - for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=